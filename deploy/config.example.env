# LensChain deploy configuration example
# 用途：
# 1. 统一收口部署、初始化、镜像拉取和 Secret 相关的常见配置项
# 2. 作为 dev / staging / prod 配置时的参考模板
# 3. 本文件不直接被程序自动加载，主要用于指导使用者按环境准备参数

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=5442
DB_USER=lenschain
DB_PASSWORD=lenschain
DB_NAME=lenschain

# ---------------------------------------------------------------------------
# Backend seed / sync
# ---------------------------------------------------------------------------

BACKEND_URL=http://localhost:8080/api/v1
ADMIN_TOKEN=CHANGE_ME

# ---------------------------------------------------------------------------
# Registry
# ---------------------------------------------------------------------------

REGISTRY_SERVER=registry.lianjing.com
REGISTRY_USER=CHANGE_ME
REGISTRY_PASSWORD=CHANGE_ME
REGISTRY_PULL_SECRET_NAME=registry-pull-secret

# ---------------------------------------------------------------------------
# K8s
# ---------------------------------------------------------------------------

K8S_NAMESPACE=lenschain
K8S_PLATFORM_NAMESPACE=lenschain
K8S_IMAGE_PULL_SECRET_NAME=registry-pull-secret

# ---------------------------------------------------------------------------
# Backend Secret
# ---------------------------------------------------------------------------

BACKEND_SECRET_NAME=backend-secret
BACKEND_DATABASE_PASSWORD=CHANGE_ME
BACKEND_JWT_ACCESS_SECRET=CHANGE_ME
BACKEND_JWT_REFRESH_SECRET=CHANGE_ME

# ---------------------------------------------------------------------------
# PostgreSQL Secret
# ---------------------------------------------------------------------------

POSTGRES_SECRET_NAME=postgres-secret
POSTGRES_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# MinIO Secret
# ---------------------------------------------------------------------------

MINIO_SECRET_NAME=minio-secret
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Ingress / Domain
# ---------------------------------------------------------------------------

APP_HOST=app.lianjing.com
API_HOST=api.lianjing.com
FILES_HOST=files.lianjing.com
CONSOLE_HOST=console.lianjing.com

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------

# 1. 本地开发可以直接使用 DB_* 默认值
# 2. staging / prod 必须替换所有 CHANGE_ME
# 3. registry-pull-secret 同时用于：
#    - 平台静态 Deployment
#    - 模块04/05 动态创建的实验 / 竞赛 namespace

