# 链镜平台部署配置示例
#
# 用途：
#   1. 统一收口部署、初始化、镜像拉取和 Secret 相关的配置项
#   2. 作为 dev / staging / prod 配置时的参考模板
#   3. 本文件不直接被程序加载，仅用于指导使用者按环境准备参数
#   4. 使用时复制为 config.env 并填入真实值；config.env 已被 .gitignore 忽略
#
# 密码生成方式：
#   - 32 位随机密码（适用于数据库、Redis、MinIO）：
#     Linux/macOS: openssl rand -base64 32
#     PowerShell:  [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])
#
#   - 64 位十六进制密钥（适用于 JWT Secret）：
#     Linux/macOS: openssl rand -hex 32
#     PowerShell:  -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) })
#
# 注意事项：
#   1. 本地开发可使用 docker-compose.dev.yml 中的默认值
#   2. staging / prod 必须使用上述命令为每个 CHANGE_ME 字段生成独立的强密码
#   3. backend-secret 中的 database-password 必须与 postgres-secret 的 password 一致
#   4. backend-secret 中的 redis-password 必须与 redis-secret 的 password 一致
#   5. registry-pull-secret 同时用于平台静态 Deployment 和模块04/05 动态创建的实验/竞赛 Namespace

# ---------------------------------------------------------------------------
# 数据库（本地开发 / 脚本初始化）
# ---------------------------------------------------------------------------

# host: 数据库主机地址
DB_HOST=localhost
# port: 数据库端口（本地开发映射端口，与 docker-compose.dev.yml 一致）
DB_PORT=5442
# user: 数据库用户名
DB_USER=lenschain
# password: 数据库密码；生产环境必须替换
DB_PASSWORD=CHANGE_ME
# dbname: 数据库名
DB_NAME=lenschain

# ---------------------------------------------------------------------------
# 后端种子数据 / 镜像同步
# ---------------------------------------------------------------------------

# url: 后端 API 基础地址
BACKEND_URL=http://localhost:8080/api/v1
# admin_token: 超级管理员 Token；通过登录接口获取
ADMIN_TOKEN=CHANGE_ME

# ---------------------------------------------------------------------------
# 镜像仓库
# ---------------------------------------------------------------------------

# server: 镜像仓库地址
REGISTRY_SERVER=registry.lianjing.com
# user: 镜像仓库用户名
REGISTRY_USER=CHANGE_ME
# password: 镜像仓库密码
REGISTRY_PASSWORD=CHANGE_ME
# pull_secret_name: K8s 镜像拉取 Secret 名称
REGISTRY_PULL_SECRET_NAME=registry-pull-secret

# ---------------------------------------------------------------------------
# K8s 基础配置
# ---------------------------------------------------------------------------

# namespace: 平台核心服务命名空间
K8S_NAMESPACE=lenschain
# platform_namespace: 平台命名空间（与 namespace 一致）
K8S_PLATFORM_NAMESPACE=lenschain
# image_pull_secret_name: 镜像拉取 Secret 名称
K8S_IMAGE_PULL_SECRET_NAME=registry-pull-secret

# ---------------------------------------------------------------------------
# 后端 Secret（K8s Secret: backend-secret）
# ---------------------------------------------------------------------------

# secret_name: Secret 资源名称
BACKEND_SECRET_NAME=backend-secret
# database-password: 数据库密码；使用 32 位随机密码生成
BACKEND_DATABASE_PASSWORD=CHANGE_ME
# jwt-access-secret: Access Token 签名密钥；使用 64 位十六进制密钥生成
BACKEND_JWT_ACCESS_SECRET=CHANGE_ME
# jwt-refresh-secret: Refresh Token 签名密钥；使用 64 位十六进制密钥生成
BACKEND_JWT_REFRESH_SECRET=CHANGE_ME
# redis-password: Redis 密码；使用 32 位随机密码生成，必须与 REDIS_PASSWORD 一致
BACKEND_REDIS_PASSWORD=CHANGE_ME
# snapshot-encryption-key: SimEngine 快照加密密钥；使用 64 位十六进制密钥生成
BACKEND_SNAPSHOT_ENCRYPTION_KEY=CHANGE_ME

# ---------------------------------------------------------------------------
# PostgreSQL Secret（K8s Secret: postgres-secret）
# ---------------------------------------------------------------------------

# secret_name: Secret 资源名称
POSTGRES_SECRET_NAME=postgres-secret
# password: PostgreSQL 密码；必须与 BACKEND_DATABASE_PASSWORD 一致
POSTGRES_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Redis Secret（K8s Secret: redis-secret）
# ---------------------------------------------------------------------------

# secret_name: Secret 资源名称
REDIS_SECRET_NAME=redis-secret
# password: Redis 密码；必须与 BACKEND_REDIS_PASSWORD 一致
REDIS_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# MinIO Secret（K8s Secret: minio-secret）
# ---------------------------------------------------------------------------

# secret_name: Secret 资源名称
MINIO_SECRET_NAME=minio-secret
# root-user: MinIO 管理员用户名
MINIO_ROOT_USER=minioadmin
# root-password: MinIO 管理员密码；使用 32 位随机密码生成
MINIO_ROOT_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Ingress 域名
# ---------------------------------------------------------------------------

# app_host: 前端应用域名
APP_HOST=app.lianjing.com
# api_host: 后端 API 域名
API_HOST=api.lianjing.com
# files_host: 文件存储域名（MinIO S3 API）
FILES_HOST=files.lianjing.com
# console_host: MinIO 管理控制台域名（建议仅内网可达）
CONSOLE_HOST=console.lianjing.com

